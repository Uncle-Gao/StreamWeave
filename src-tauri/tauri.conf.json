{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "StreamWeave",
  "mainBinaryName": "StreamWeave",
  "version": "0.1.0",
  "identifier": "com.uncle.streamweave",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "StreamWeave",
        "width": 1200,
        "height": 760,
        "minWidth": 1100,
        "minHeight": 680
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "infoPlist": "Info.plist"
    }
  }
}
